# KIRA AI — Environment Variables
# Copy this file to .env and fill in your keys.
# Never commit .env to git.

# Required from day one
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=...

# Optional — only needed if you switch the wake engine to Porcupine.
# Default engine is openWakeWord (no key required). To use Porcupine instead,
# set WAKE_ENGINE = "porcupine" in config/settings.py and fill this in.
# PORCUPINE_ACCESS_KEY=...

# Required for Phase 2 (Google OAuth)
# Get from console.cloud.google.com — download credentials.json
# Then run: python scripts/setup_google_auth.py

# Required for Phase 3 (memory embeddings)
OPENAI_API_KEY=sk-...

# Required for Phase 2 (weather)
OPENWEATHER_API_KEY=...

# Database (Phase 3) — leave as-is if using local Docker
DATABASE_URL=postgresql://kira:kira@localhost:5432/kiradb
